# === QubitPage® OS — Environment Variables Template ===
# Copy to /etc/qubitpage/keys.env and fill in your values.
# DO NOT commit this file to Git.

# --- Google AI ---
# Get free API key at: https://aistudio.google.com
GEMINI_API_KEY=

# --- Groq (free 14,400 req/day) ---
# Get free API key at: https://console.groq.com
GROQ_API_KEY=

# --- IBM Quantum (optional — simulators work without this) ---
# Get token at: https://quantum.ibm.com → Account → Copy token
IBM_QUANTUM_TOKEN=

# --- Amazon Braket (optional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- Flask Server ---
# Change this to a random 32-char string for production
FLASK_SECRET=change-me-to-a-random-32-char-string
FLASK_DEBUG=0

# --- Optional AI Service Tokens (if running local AI service cluster) ---
# These are only needed if you deploy the full HAI-DEF model cluster
MEDGEMMA_TOKEN=
MULTIMODEL_TOKEN=
TXGEMMA_TOKEN=
HEAR_TOKEN=
CXR_TOKEN=
PATHFOUND_TOKEN=
